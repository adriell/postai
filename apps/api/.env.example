# ── Database ──────────────────────────────────────────────────
# Supabase: use a Transaction Pooler URL (porta 6543)
# Local Docker: deixe DATABASE_URL em branco e preencha as vars abaixo
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Usado apenas quando DATABASE_URL não está definida (desenvolvimento local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postai
DB_USER=postai_user
DB_PASS=postai_secret_local

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-aleatoria-longa

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=PostAI <noreply@seudominio.com.br>

# ── App ──────────────────────────────────────────────────────
APP_URL=https://seuapp.vercel.app
NODE_ENV=production
PORT=3011

# ── CORS ─────────────────────────────────────────────────────
# Separe múltiplas origens por vírgula
CORS_ORIGINS=https://seuapp.vercel.app
